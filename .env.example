# WebPass Environment Configuration

# JWT secret key for signing tokens (required)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-32-byte-hex-string-here

# Path to SQLite database file (optional)
# Default: /data/db/db.sqlite3
DB_PATH=/data/db/db.sqlite3

# Directory containing frontend static files (optional)
# Default: frontend/dist
STATIC_DIR=frontend/dist

# Disable frontend serving (optional)
# Set to "1" or "true" to disable even if STATIC_DIR exists
# Default: false (frontend enabled)
# DISABLE_FRONTEND=1

# HTTP listen port (optional)
# Default: 8080
# PORT=8080

# Git repository root for git sync feature (optional)
# Default: /data/git-repos
# GIT_REPO_ROOT=/data/git-repos

# CORS allowed origins (optional)
# Comma-separated list of allowed origins
# If not set, all origins are allowed (development only)
# CORS_ORIGINS=https://webpass.example.com,https://webpass.pages.dev
