# WebPass Environment Configuration

# JWT secret key for signing tokens (required)
# Generate with: openssl rand -hex 32
# 
# Note: If not set, a random key is generated on each startup.
# This is fine for single-instance deployments with short sessions.
# Set a fixed value for:
#   - Multi-instance deployments (load balancer with multiple pods)
#   - Long session durations (don't want restarts to invalidate sessions)
#   - Production environments requiring predictable behavior
JWT_SECRET=your-random-32-byte-hex-string-here

# Path to SQLite database file (optional)
# Docker: DB_PATH=/data/db/db.sqlite3
# Local dev: DB_PATH=./data/db/db.sqlite3
DB_PATH=./data/db/db.sqlite3

# Directory containing frontend static files (optional)
# Default: frontend/dist
STATIC_DIR=frontend/dist

# Disable frontend serving (optional)
# Set to "1" or "true" to disable even if STATIC_DIR exists
# Default: false (frontend enabled)
# DISABLE_FRONTEND=1

# HTTP listen port (optional)
# Default: 8080
# PORT=8080

# Git repository root for git sync feature (optional)
# Default: /data/git-repos (use ./git-repos for local development)
# Docker: GIT_REPO_ROOT=/data/git-repos
# Local dev: GIT_REPO_ROOT=./git-repos
GIT_REPO_ROOT=./git-repos

# CORS allowed origins (optional)
# Comma-separated list of allowed origins
# If not set, all origins are allowed (development only)
# CORS_ORIGINS=https://webpass.example.com,https://webpass.pages.dev

# Session duration in minutes (optional)
# Default: 5, Valid range: 5-480 (5 minutes to 8 hours)
# Invalid values will use default and print a warning
# SESSION_DURATION_MINUTES=5
