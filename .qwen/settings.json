{
  "$version": 3,
  "permissions": {
    "allow": [
      "Bash(./frontend/playwright-e2e-test.sh *)",
      "Bash(./playwright-e2e-test.sh *)",
      "Bash(docker compose *)",
      "Bash(docker compose build *)",
      "Bash(docker compose down)",
      "Bash(docker compose up *)",
      "Bash(docker logs *)",
      "Bash(docker ps)",
      "Bash(gh *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(go *)",
      "Bash(golangci-lint *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(rm *)",
      "Bash(sleep *)",
      "Bash(sqlc *)",
      "Bash(tee *)",
      "Bash(~/go/bin/sqlc *)",
      "Bash(git tag *)",
      "Bash(cat *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Bash(git reset --hard *)",
      "Bash(rm -rf / *)",
      "Bash(rm -rf ~ *)"
    ]
  },
  "confirm": {
    "commands": [
      "git push *",
      "git merge *",
      "git rebase *"
    ]
  },
  "denyPaths": [
    "**/.env",
    "**/.env.*",
    "**/secrets/**",
    "**/*.key",
    "**/*.pem",
    "**/production/**"
  ]
}